{
  "name": "tournament-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backbone for a sports tournament platform API (Fastify + Drizzle + Postgres)",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "drizzle-kit": "^0.24.2",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
