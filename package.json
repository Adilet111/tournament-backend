{
  "name": "tournament-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backbone for a sports tournament platform API (Fastify + Drizzle + Postgres)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "rm -rf dist/modules/profiles/definitions && mkdir -p dist/modules/profiles/definitions && cp src/modules/profiles/definitions/*.json dist/modules/profiles/definitions/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/tests/authz.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/cors": "^11.3.0",
    "@fastify/jwt": "^10.2.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "google-auth-library": "^10.7.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
